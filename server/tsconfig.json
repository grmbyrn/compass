{
  "compilerOptions": {
    /* File Layout */
    "outDir": "./dist",

    /* Environment */
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020"],
    "types": ["node"],

    /* Node compatibility */
    "esModuleInterop": true,

    /* Output */
    "sourceMap": true,

    /* Strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* DX */
    "skipLibCheck": true
  },
  "include": ["src", "prisma.config.ts"]
}
